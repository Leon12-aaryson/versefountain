# PostgreSQL Database Connection (commented for MySQL migration)
# DATABASE_URL=${DATABASE_URL}
# PGHOST=${PGHOST}
# PGDATABASE=${PGDATABASE}
# PGUSER=${PGUSER}
# PGPASSWORD=${PGPASSWORD}
# PGPORT=${PGPORT}

# MySQL Database Connection
MYSQL_DATABASE_URL=mysql://root:password@localhost:3306/versefountain
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=versefountain
MYSQL_USER=root
MYSQL_PASSWORD=root

# Session Secret
SESSION_SECRET=versefountain-session-secret-key-0123456789

# App Configuration
PORT=5000
NODE_ENV=development
